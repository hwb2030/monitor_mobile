page {
  --bg: #0d0d1a;
  --surface: #16162a;
  --surface2: #1e1e3a;
  --border: #2a2a4a;
  --text: #e0e0f0;
  --text2: #8888aa;
  --player-color: #6ab0ff;
  --accent: #d4a84a;
  
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
