page {
  --bg: #0d0d1a; --surface: #16162a; --surface2: #1e1e3a; --border: #2a2a4a;
  --text: #e0e0f0; --text2: #8888aa; --accent: #d4a84a;
  background: var(--bg); color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  height: 100vh;
}
.settings-page { padding: 24rpx; }
.settings-title { font-size: 32rpx; font-weight: 700; text-align: center; color: var(--accent); margin-bottom: 20rpx; }
.char-tabs { display: flex; gap: 10rpx; margin-bottom: 20rpx; white-space: nowrap; }
.tab-item {
  display: inline-flex; padding: 10rpx 24rpx; border-radius: 28rpx; border: 2rpx solid var(--border);
  background: transparent; font-size: 24rpx; margin-right: 10rpx;
}
.tab-item.active { background: rgba(255,255,255,0.08); border-color: var(--accent); }
.label { display: block; font-size: 22rpx; color: var(--text2); margin-bottom: 8rpx; }
.prompt-editor {
  width: 100%; background: var(--surface2); border: 1px solid var(--border); color: var(--text);
  border-radius: 12rpx; padding: 16rpx; font-size: 24rpx; min-height: 500rpx; box-sizing: border-box;
}
.prompt-editor:focus { border-color: var(--accent); }
.btn-row { display: flex; gap: 16rpx; margin-top: 20rpx; justify-content: center; }
.btn-save { background: var(--accent); color: #1a1a2e; padding: 16rpx 48rpx; border-radius: 12rpx; font-size: 26rpx; font-weight: 600; }
.btn-close { background: var(--surface2); color: var(--text2); padding: 16rpx 48rpx; border-radius: 12rpx; border: 1px solid var(--border); font-size: 26rpx; }
