page {
  --bg: #0d0d1a; --surface: #16162a; --surface2: #1e1e3a; --border: #2a2a4a;
  --text: #e0e0f0; --text2: #8888aa; --accent: #d4a84a;
  background: var(--bg); color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  height: 100vh;
}
.settings-page { padding: 30rpx; display: flex; flex-direction: column; }
.settings-title { font-size: 34rpx; font-weight: 700; color: var(--accent); text-align: center; margin-bottom: 24rpx; }
.char-tabs { display: flex; gap: 12rpx; white-space: nowrap; margin-bottom: 24rpx; }
.tab-item {
  display: inline-block; padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 24rpx;
  border: 1px solid var(--border); background: var(--surface2);
}
.tab-item.active { background: rgba(255,255,255,0.08); border-width: 2rpx; }
.label { font-size: 24rpx; color: var(--text2); margin-bottom: 12rpx; }
.prompt-editor {
  width: 100%; height: 600rpx; background: var(--surface2); border: 1px solid var(--border);
  border-radius: 16rpx; padding: 20rpx; font-size: 24rpx; color: var(--text); line-height: 1.6;
  box-sizing: border-box;
}
.btn-row { display: flex; gap: 16rpx; margin-top: 24rpx; justify-content: center; }
.btn-save, .btn-close { flex: 1; padding: 16rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 600; text-align: center; }
.btn-save { background: linear-gradient(135deg, #d4a84a, #b8922a); color: #1a1a2e; }
.btn-close { background: var(--surface2); border: 1px solid var(--border); color: var(--text); }
