page {
  --bg: #0d0d1a; --surface: #16162a; --surface2: #1e1e3a; --border: #2a2a4a;
  --text: #e0e0f0; --text2: #8888aa; --player-color: #6ab0ff; --accent: #d4a84a;
  background: var(--bg); color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  height: 100vh; width: 100vw; overflow: hidden;
}
.header {
  background: linear-gradient(135deg, #1a0a2e 0%, #16213e 50%, #0a1a2e 100%);
  border-bottom: 1px solid var(--border); padding: 24rpx 30rpx; flex-shrink: 0; text-align: center;
}
.header-title { font-size: 36rpx; font-weight: 700; letter-spacing: 4rpx; }
.hl { color: var(--accent); }
.subtitle { font-size: 22rpx; color: var(--text2); margin-top: 4rpx; }
.roster { display: flex; justify-content: center; flex-wrap: wrap; margin-top: 10rpx; }
.roster-item {
  font-size: 22rpx; margin: 4rpx 10rpx; padding: 4rpx 16rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.04); display: flex; align-items: center; gap: 6rpx;
}
.roster-dot { width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0; }
.container {
  display: flex; flex-direction: column;
  height: 100vh; width: 100vw;
  position: fixed; top: 0; left: 0;
  background: var(--bg);
}
.chat-container { flex: 1; padding: 24rpx 30rpx; overflow-y: auto; display: flex; flex-direction: column; }
.system-msg { text-align: center; font-size: 22rpx; color: var(--text2); padding: 8rpx 0; margin-bottom: 12rpx; }
.badge {
  display: inline-block; padding: 4rpx 24rpx; border-radius: 20rpx;
  background: rgba(255,255,255,0.04); border: 1px solid var(--border);
}
.message { display: flex; gap: 16rpx; max-width: 88%; margin-bottom: 16rpx; }
.message.player { flex-direction: row-reverse; justify-content: flex-start; margin-left: auto; }
.message.ai { justify-content: flex-start; margin-right: auto; }
.avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%; display: flex; align-items: center;
  justify-content: center; font-size: 42rpx; flex-shrink: 0; border: 4rpx solid;
}
.message.player .avatar { background: linear-gradient(135deg, #2b4f8c, #1a3060) !important; border-color: var(--player-color) !important; }
.bubble { padding: 16rpx 24rpx; border-radius: 24rpx; font-size: 26rpx; line-height: 1.6; word-break: break-word; }
.message.player .bubble { background: linear-gradient(135deg, #1a5a3a, #0f4a2a); border: 1px solid #2a8a5a; border-bottom-right-radius: 8rpx; }
.message.ai .bubble { background: var(--surface2); border: 1px solid var(--border); border-bottom-left-radius: 8rpx; }
.name-row { display: flex; gap: 8rpx; margin-bottom: 6rpx; }
.name { font-size: 22rpx; font-weight: 600; }
.time { font-size: 18rpx; color: var(--text2); margin-top: 6rpx; text-align: right; }
.content { white-space: pre-wrap; }
.typing-indicator { display: none; gap: 6rpx; padding: 16rpx 24rpx; background: var(--surface2); border-radius: 24rpx; border-bottom-left-radius: 8rpx; margin-bottom: 16rpx; width: 120rpx; align-self: flex-start; }
.typing-indicator.show { display: flex; }
.dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: var(--text2); animation: bounce 1.4s infinite ease-in-out both; }
.dot:nth-child(2) { animation-delay: 0.16s; }
.dot:nth-child(3) { animation-delay: 0.32s; }
@keyframes bounce { 0%, 80%, 100% { transform: scale(0.6); } 40% { transform: scale(1); } }
.input-area {
  display: flex; gap: 8rpx; padding: 12rpx 16rpx;
  padding-bottom: calc(12rpx + env(safe-area-inset-bottom, 0rpx));
  background: var(--surface); border-top: 1px solid var(--border);
  align-items: center; flex-shrink: 0;
}
.msg-input {
  flex: 1; min-width: 0;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 8rpx; color: var(--text); padding: 10rpx 16rpx;
  font-size: 28rpx; height: 64rpx; box-sizing: border-box;
  outline: none;
}
.send-btn {
  background: linear-gradient(135deg, #07c160, #06ad56); border: none;
  color: #fff; padding: 0 24rpx; border-radius: 8rpx;
  font-size: 28rpx; font-weight: 500; white-space: nowrap;
  height: 64rpx; line-height: 64rpx; flex-shrink: 0; text-align: center;
}
.send-btn-disabled {
  opacity: 0.5;
}
.auto-btn {
  display: none;
}
.header-actions { margin-top: 10rpx; display: flex; align-items: center; justify-content: center; gap: 16rpx; }
.settings-link { font-size: 22rpx; color: var(--accent); opacity: 0.8; display: inline-block; padding: 4rpx 12rpx; }
.auto-btn-header {
  background: var(--surface2); border: 1px solid var(--border); color: var(--text);
  padding: 6rpx 20rpx; border-radius: 24rpx; font-size: 22rpx; white-space: nowrap;
  height: 48rpx; line-height: 34rpx; flex-shrink: 0;
}
.auto-btn-header.auto-active-header {
  background: rgba(212, 168, 74, 0.2); border-color: var(--accent); color: var(--accent);
}
