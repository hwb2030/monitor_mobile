<view class="container">
  <view class="header">
    <view class="header-title">
      <text class="hl">СЕ</text>
      <text>гы</text>
      <text class="hl">ЩюПе</text>
      <text> ЁЄ AI СФЬьШК</text>
    </view>
    <view class="subtitle">ЮхЮЛФажїНЧвбдкЯп \_(ЅФ)_/</view>
    <view class="roster">
      <view wx:for="{{characters}}" wx:key="id" class="roster-item" style="border-color: {{item.color}};">
        <view class="roster-dot" style="background: {{item.color}};"></view>
        <text style="color: {{item.color}};">{{item.emoji}} {{item.name}}</text>
      </view>
    </view>
    <view class="header-actions">
      <text class="settings-link" bindtap="goToSettings">?? ЩшжУ</text>
    </view>
  </view>
  <scroll-view class="chat-container" scroll-y="true" scroll-into-view="{{scrollToId}}" scroll-with-animation="true">
    <block wx:for="{{messages}}" wx:key="id">
      <view wx:if="{{item.type === 'system'}}" class="system-msg">
        <view class="badge">{{item.content}}</view>
      </view>
      <view wx:elif="{{item.type === 'message'}}" class="message {{item.role === 'player' ? 'player' : 'ai'}}" id="msg-{{item.id}}">
        <view class="avatar" style="background: {{item.role === 'player' ? 'linear-gradient(135deg, #2b4f8c, #1a3060)' : 'transparent'}}; border-color: {{item.color}};">
          <text>{{item.emoji}}</text>
        </view>
        <view class="bubble">
          <view class="name-row">
            <text class="name" style="color: {{item.color}};">{{item.name}}</text>
          </view>
          <view class="content">{{item.content}}</view>
          <view class="time">{{item.time}}</view>
        </view>
      </view>
    </block>
    <view class="typing-indicator {{showTyping ? 'show' : ''}}">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
  </scroll-view>
  <view class="input-area">
    <input class="msg-input" type="text" placeholder="ЪфШыЯћЯЂ..." value="{{inputValue}}" bindinput="onInput" bindconfirm="onSend" confirm-type="send" maxlength="200" />
    <button class="send-btn" bindtap="onSend" disabled="{{!inputValue.trim()}}">ЗЂЫЭ</button>
    <button class="auto-btn {{isAutoChatting ? 'auto-active' : ''}}" bindtap="onAutoChat">{{isAutoChatting ? '? ЭЃжЙ' : '?? здЖЏСФЬь'}}</button>
  </view>
</view>
